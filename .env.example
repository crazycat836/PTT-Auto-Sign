# PTT Account Settings
# 您的 PTT 帳號
PTT_USERNAME=your_username
# 您的 PTT 密碼
PTT_PASSWORD=your_password

# Telegram Notification Settings
# Telegram Bot Token (format: 123456789:ABCdefGHIjksLmnoPQRstuVWxyz)
TELEGRAM_BOT_TOKEN=your_bot_token
# Telegram Chat ID (can be user ID or channel ID)
TELEGRAM_CHAT_ID=your_chat_id
# 是否關閉通知 (true/false)
DISABLE_NOTIFICATIONS=false
# 重試次數
TELEGRAM_RETRY_COUNT=3
# Timeout 秒數
TELEGRAM_TIMEOUT=10

# PTT Settings
# 時區設定 (預設 8 為台灣時間 UTC+8)
timezone_hours=8
# 最大重試登入次數
ptt_max_retries=3
# 重試間隔秒數
ptt_retry_delay=2
# 連線 Timeout 秒數
ptt_connection_timeout=30
# 是否踢除其他登入連線 (true/false)
ptt_kick_other_session=true

# Logging Settings
# Log 格式
LOG_FORMAT=%(asctime)s [%(name)s] %(levelname)s: %(message)s
# Debug 模式 (true/false) - 開啟會顯示更多詳細資訊
DEBUG_MODE=false
# Log 等級 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Application Settings
# 測試模式 (true/false)
TEST_MODE=false
